{
  "name": "drupal/profile_split_enable",
  "type": "drupal-module",
  "description": "Allows Drupal sites using multiple profiles, CMI and config split to have a config split defined for each profile",
  "homepage": "https://www.drupal.org/project/profile_split_enable",
  "license": "GPL-2.0+",
  "authors": [
    {
      "name": "Nick Downton (nedsbeds)",
      "homepage": "https://www.drupal.org/u/nedsbeds",
      "role": "Maintainer"
    }
  ],
  "replace": {
    "nedsbeds/profile_split_enable": "*"
  },
  "support": {
    "issues": "https://www.drupal.org/project/issues/profile_split_enable",
    "source": "https://git.drupalcode.org/project/profile_split_enable"
  },
  "require": {
    "drupal/core": "^8.8 || ^9 || ^10"
  },
  "suggest": {
    "drupal/config_split": "^1.0.0"
  },
  "require-dev": {
  }
}
