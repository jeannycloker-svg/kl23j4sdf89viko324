<?php

/**
 * @file
 * Default hook implementations for the Metatag Routes module.
 */

use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\metatag_routes\Hook\HelpHooks;
use Drupal\metatag_routes\Hook\MetatagHooks;
use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
#[LegacyHook]
function metatag_routes_help($route_name, RouteMatchInterface $route_match) {
  return \Drupal::service(HelpHooks::class)->help($route_name, $route_match);
}

/**
 * Implements hook_metatags_alter().
 */
#[LegacyHook]
function metatag_routes_metatags_alter(array &$metatags, array $context) {
  \Drupal::service(MetatagHooks::class)->metatagsAlter($metatags, $context);
}
