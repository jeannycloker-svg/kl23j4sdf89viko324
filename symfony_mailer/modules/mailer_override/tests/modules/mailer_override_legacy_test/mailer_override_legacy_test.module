<?php

/**
 * @file
 * Hook implementations for the Mailer Override legacy email test module.
 */

use Drupal\Core\Render\Markup;
use Drupal\mailer_override_legacy_test\Form\LegacyTestEmailForm;

/**
 * Implements hook_mail().
 */
function mailer_override_legacy_test_mail($key, &$message, $params) {
  if ($key == 'legacy_test') {
    $message['subject'] = 'Legacy email sent via hook_mail().';
    $message['body'][] = 'This email is sent via hook_mail().';
    $message['body'][] = mailer_override_legacy_test_add_template_to_body();
    $message['headers']['Cc'] = LegacyTestEmailForm::ADDRESS_CC;
    $message['headers']['bcc'] = LegacyTestEmailForm::ADDRESS_BCC;
    // A plain-text alternative supplied as a Markup object, as senders such as
    // Easy Email and Commerce do by rendering a template. Core's PhpMail cast
    // it to a string implicitly, so the legacy bridge must accept it too.
    $message['plain'] = Markup::create('This is the plain-text alternative.');
  }
}

/**
 * Implements hook_mail_alter().
 */
function mailer_override_legacy_test_mail_alter(&$message) {
  if ($message['id'] == 'mailer_override_legacy_test_legacy_test') {
    $message['body'][] = 'This email was altered via hook_mail_alter().';
    $message['to'] = LegacyTestEmailForm::ADDRESS_TO;
    $message['headers']['Reply-to'] = LegacyTestEmailForm::ADDRESS_REPLY_TO;
  }
}

/**
 * Adds a rendered (Twig) template file to the body of the test email message.
 *
 * This mimics the logic implemented in Drupal Commerce, when sending the
 * "commerce order receipt" mail.
 */
function mailer_override_legacy_test_add_template_to_body() {
  /** @var \Drupal\Core\Theme\ThemeManagerInterface $theme_manager */
  $theme_manager = \Drupal::service('theme.manager');
  /** @var \Drupal\Core\Render\RendererInterface $renderer */
  $renderer = \Drupal::service('renderer');
  $current_theme = $theme_manager->getActiveTheme()->getName();
  $template = [
    '#theme' => 'legacy_test_email',
    '#current_theme' => $current_theme,
  ];
  return $renderer->render($template);
}

/**
 * Implements hook_theme().
 */
function mailer_override_legacy_test_theme() {
  return [
    'legacy_test_email' => [
      'variables' => ['current_theme' => NULL],
    ],
  ];
}
